# ── Experiment ──
EXPERIMENT__experiment_id=
EXPERIMENT__max_turns=1
EXPERIMENT__samples_per_problem=1
EXPERIMENT__feedback_strategy=error_message

# ── LLM ──
LLM__api_key=
LLM__base_url=
LLM__model=
LLM__llm_type=openai_compatible
LLM__concurrency=1
LLM__max_retries=3
LLM__retry_base_delay=1.0

# ── Dataset ──
DATASET__cache_dir=data/cache
DATASET__dataset_name=

# ── Docker ──
DOCKER__cpus=1.0
DOCKER__memory=512m
DOCKER__memory_swap=512m
DOCKER__memory_reservation=256m
DOCKER__network_mode=none
DOCKER__device_read_bps=128m
DOCKER__device_write_bps=128m
DOCKER__timeout=10

# ── Evaluator ──
EVALUATOR__evaluator_type=docker
EVALUATOR__concurrency=1

# ── Logger ──
LOG__level=INFO
LOG__log_file=

# ── Experiment ──
EXPERIMENT_ID=
MAX_TURNS=1
SAMPLES_PER_PROBLEM=1

# ── Executor ──
EXECUTOR__api_key=
EXECUTOR__base_url=
EXECUTOR__model=
EXECUTOR__executor_type=chat_llm
EXECUTOR__concurrency=1
EXECUTOR__max_retries=3
EXECUTOR__retry_base_delay=1.0

# ── Dataset ──
DATASET__cache_dir=data/cache
DATASET__dataset_name=

# ── Docker ──
DOCKER__cpus=1.0
DOCKER__memory=512m
DOCKER__memory_swap=512m
DOCKER__memory_reservation=256m
DOCKER__network_mode=none
DOCKER__device_read_bps=128m
DOCKER__device_write_bps=128m
DOCKER__timeout=10

# ── Evaluator ──
EVALUATOR__evaluator_type=docker
EVALUATOR__concurrency=1

# ── Logger ──
LOG__level=INFO
LOG__log_file=
